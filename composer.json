{
    "name": "spyrosoft/magento2-google-ucp",
    "description": "This module adds support for Google Universal Checkout Platform (UCP) integration",
    "type": "magento2-module",
    "readme": "README.md",
    "license": [
        "Apache-2.0"
    ],
    "authors": [
        {
            "name": "Spyrosoft",
            "homepage": "https://spyro-soft.com/"
        }
    ],
    "config": {
        "sort-packages": true
    },
    "require": {
        "magento/framework": "*",
        "php": "^8.1",
        "przelewy24/magento2-przelewy24": "^1.4"
    },
    "repositories": [
        {
            "type": "composer",
            "url": "https://github.com/Spyrosoft-eCommerce-S-A/magento2-google-ucp"
        }
    ],
    "autoload": {
        "files": [
            "registration.php"
        ],
        "psr-4": {
            "Spyrosoft\\Ucp\\": ""
        }
    },

    "version": "1.1.0"
}
